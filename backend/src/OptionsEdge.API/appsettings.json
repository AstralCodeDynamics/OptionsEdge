{
  "App": {
    "FrontendUrl": "http://localhost:5173"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "LogFiles": {
    "Directory": "logs",
    "FileNamePrefix": "optionsedge-",
    "RetentionDays": 7,
    "CleanupTimeLocal": "00:00:00"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Claude": {
    "HaikuModel": "claude-haiku-4-5-20251001",
    "SonnetModel": "claude-sonnet-4-6",
    "BypassMarketHours": false
  },
  "Groww": {
    "Enabled": false,
    "BaseUrl": "https://api.groww.in",
    "OrderPlacementEnabled": false
  },
  "Backtest": {
    "HistoryRetentionDays": 30
  },
  "LotSizes": {
    "NIFTY": 65,
    "BANKNIFTY": 30
  },
  "Encryption": {
    "Key": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "OptionsEdge",
    "Audience": "OptionsEdge",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "AuthSettings": {
    "RequireEmailConfirmation": true,
    "RequireTwoFactor": true,
    "EnableLockout": true,
    "SendRealEmails": true
  },
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "FromAddress": "noreply@optionsedge.local",
    "FromName": "OptionsEdge"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "https://localhost:5173" ]
  },
  "Dev": {
    "UserId": "00000000-0000-0000-0000-000000000001"
  }
}
